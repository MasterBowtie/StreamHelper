generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model house {
  id    Int      @id @default(autoincrement())
  wall  String?  @db.VarChar(10)
  roof  String?  @db.VarChar(10)
  style String?  @db.VarChar(10)
  used  Boolean? @default(false)
}

model user {
  id        Int       @id @default(autoincrement())
  name      String    @unique(map: "name") @db.VarChar(20)
  token     String?   @db.VarChar(100)
  refresh   String?   @db.VarChar(50) 
  expires   String?   @db.VarChar(50) 
  client_id String    @unique(map: "client_id") @db.VarChar(50)
  user_id   String?   @db.VarChar(20)
}

model subscriber {
  id              Int       @id @unique
  user_name       String    
  start_date      String    @db.VarChar(50)
  tier            Int
  gifted          Boolean?   @default(false)
  gifted_by_id    Int?
  gifted_by_name  String?
  resub_date      String?    @db.VarChar(50)
}

model Scripture {
  id        Int       @id @default(autoincrement())
  date      DateTime  @default(now())

  // Refers to collection (1: OT, 2: NT, 3: BoM, 4: D&C)
  book      Int    
  collection Collection @relation(fields: [book], references: [id], onDelete: Restrict)   

  body Json      // paragraphs of scripture text
  reference String    // e.g. "Matthew 22:36-39"

  // Generated month–day column for "today across years"
  md        String    @db.Char(5) @default(dbgenerated("(date_format(`date`,'%m-%d'))"))

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([md], name: "idx_scripture_md")
  @@index([book], name: "idx_scripture_book")
}

model Collection {
  id    Int     @id
  name  String  @unique

  scriptures Scripture[]
}

